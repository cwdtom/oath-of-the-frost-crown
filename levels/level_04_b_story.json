[
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "怎么会……我已经得到了这么多力量……"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "结束了，父王。兽灵烙印正在消失。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "不……还不能结束。战争还会回来，王国还没有准备好……"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "你已经保护不了任何人了。继续下去，只会让更多人死去。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "我只是……不想再看见那些村庄燃烧。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "那一年，我在废墟里找到你。雪落在灰烬上，你那么小。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "是你把我带回了王都。也是你告诉我，剑应该用来守护弱者。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "可我最后……却变成了需要被你阻止的人。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "我本以为，只要永远服从你，就能报答你给我的一切。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "但莱夫让我明白，骑士不能只做王座的剑。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "莱夫……是我害死了他。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "是。但我不会让他的牺牲只留下仇恨。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "你恨我吗？"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "我不知道。我只知道，我不能让你继续伤害这个王国。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "很好……至少你没有像我一样，被恐惧控制。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "艾拉，你没有背叛我。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "你只是终于成为了真正的骑士。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "父王……"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "别为我停下。黑冬还没有结束，人民还在等你。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "瓦尔德玛",
		"content": "你做得对……我的孩子。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar-dying.png",
		"name": "艾拉",
		"content": "我会守住这个王国。不是为了王座，而是为了所有还活着的人。"
	}
]
