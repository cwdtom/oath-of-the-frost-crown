[
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "艾拉……你还是回来了。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "父王，停下仪式。森林里的邪神从来都不存在。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "伊瓦尔告诉你了多少？"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "足够让我知道，黑冬、那些怪物，还有莱夫的死，都来自兽灵烙印。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "莱夫的死是个意外。我从未想过伤害你。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "你想杀死维德尔，也想杀死所有知道真相的人。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "因为真相救不了这个王国，力量可以。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "你夺走兽灵的力量，毁掉森林，再让人民相信是森林背叛了他们。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "你没有见过下一场战争。城墙会倒塌，村庄会燃烧，孩子会死在雪里。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "我不能再让那一天发生。无论付出什么代价。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "可现在死在雪里的，正是你想保护的人。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "只要仪式完成，黑冬就会服从我。军队不会再败，王国也不会再恐惧任何敌人。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "看看你自己。那份力量已经把你变成了什么？"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "我依然是艾尔斯维克的国王，也是你的父亲。放下剑，我可以原谅你。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "是你教我拿起剑，保护那些无法保护自己的人。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "所以今天，我不能服从你。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "你要为了那些野兽，背叛自己的王座？"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "我不是为了森林背叛王座。我是为了王国，阻止王座继续伤害它。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "没有我的力量，这个王国什么都守不住！"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "艾拉",
		"content": "那就让我守给你看。"
	},
	{
		"left": "res://assets/ui/characters/aila.png",
		"right": "res://assets/ui/characters/valdemar.png",
		"name": "瓦尔德玛",
		"content": "既然如此，就让我看看——你是否真的有资格违抗你的王。"
	}
]
